{
  "name": "@noam237/contracts",
  "version": "0.1.0",
  "description": "Cross-service contract source-of-truth for the Sabon Michal ecosystem (ERP, CRM, store). Webhook event schemas, REST endpoint contracts, shared enums, and inter-service auth/signing utilities.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks/index.d.ts",
      "import": "./dist/webhooks/index.js"
    },
    "./rest": {
      "types": "./dist/rest/index.d.ts",
      "import": "./dist/rest/index.js"
    },
    "./enums": {
      "types": "./dist/enums.d.ts",
      "import": "./dist/enums.js"
    },
    "./formats": {
      "types": "./dist/formats.d.ts",
      "import": "./dist/formats.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./webhook-signing": {
      "types": "./dist/webhook-signing.d.ts",
      "import": "./dist/webhook-signing.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.0",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/noam237/contracts.git"
  },
  "license": "UNLICENSED",
  "private": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "sabonmichal",
    "contracts",
    "zod",
    "webhooks"
  ]
}
